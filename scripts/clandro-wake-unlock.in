#!/bin/sh

if [ $# != 0 ]; then
	echo 'usage: clandro-wake-unlock'
	echo 'Release the Clandro wake lock to allow the CPU to sleep.'
	exit 1
fi

case "${CLANDRO__USER_ID:-}" in ''|*[!0-9]*|0[0-9]*) CLANDRO__USER_ID=0;; esac

am startservice \
	--user "$CLANDRO__USER_ID" \
	-a "@CLANDRO_APP_PACKAGE@.service_wake_unlock" \
	"@CLANDRO_APP_PACKAGE@/@CLANDRO_APP_PACKAGE@.app.ClandroService" \
	> /dev/null
