#!/bin/bash

unset LD_PRELOAD LD_LIBRARY_PATH

AM_APK_PATH="@CLANDRO_PREFIX@/libexec/clandro-am/am.apk"
AM_APK_TMP_PATH="@CLANDRO_CACHE_DIR@/clandro-am/am.apk"

echo
echo "You are going to reset your Clandro installation."
echo
echo "This script will erase everything under \$PREFIX. All files in that directory will be lost, that includes packages, configuration files, databases, etc."
echo
echo "Clandro home directory as well as data in your shared or external storage will not be removed and left as-is."
echo

read -re -p "Do you want to continue ? (y/n) " CHOICE

if ! [[ $CHOICE =~ (Y|y) ]]; then
	echo "Leaving \$PREFIX intact."
	exit 1
else
	HAS_CLANDRO_AM=false

	if [ -f "$AM_APK_PATH" ]; then
		HAS_CLANDRO_AM=true

		echo "Preserving package 'clandro-am' for later use..."

		if [ -d "@CLANDRO_CACHE_DIR@" ]; then
			/system/bin/rm -rf "@CLANDRO_CACHE_DIR@/clandro-am"
			/system/bin/mkdir -p "@CLANDRO_CACHE_DIR@/clandro-am"
			/system/bin/cp "$AM_APK_PATH" "$AM_APK_TMP_PATH"

			# In case copying am.apk failed.
			if [ ! -e "$AM_APK_TMP_PATH" ]; then
				HAS_CLANDRO_AM=false
			fi
		fi
	fi

	echo "Erasing '@CLANDRO_PREFIX@'..."
	/system/bin/chmod -R 700 "@CLANDRO_PREFIX@" >/dev/null 2>&1
	/system/bin/rm -rf "@CLANDRO_PREFIX@"
	echo "Done. You need to close Clandro application now."

	if ! $HAS_CLANDRO_AM; then
		echo "Terminating all sessions..."
		/system/bin/killall -9 "$SHELL"
	else
		# - https://github.com/clandro/ClandroAm/commit/598a9c06
		if [ -w "$AM_APK_TMP_PATH" ]; then
			chmod 0400 "$AM_APK_TMP_PATH"
		fi

		export CLASSPATH="$AM_APK_TMP_PATH"
		/system/bin/app_process -Xnoimage-dex2oat / "com.clandro.clandroam.Am" stopservice "@CLANDRO_APP_PACKAGE@/@CLANDRO_APP_PACKAGE@.app.ClandroService"
	fi
fi
