#!/bin/sh

if [ "$#" != "0" ]; then
	echo 'usage: clandro-reload-settings'
	echo 'Use without arguments to reload settings after modifying any of:'
	echo '  ~/.clandro/colors.properties'
	echo '  ~/.clandro/font.ttf '
	echo '  ~/.clandro/clandro.properties'
	exit
fi

case "${CLANDRO__USER_ID:-}" in ''|*[!0-9]*|0[0-9]*) CLANDRO__USER_ID=0;; esac

am broadcast --user "$CLANDRO__USER_ID" -a "@CLANDRO_APP_PACKAGE@.app.reload_style" "@CLANDRO_APP_PACKAGE@" > /dev/null
